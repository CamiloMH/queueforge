# ─────────────────────────── Aplicación ───────────────────────────
# Entorno activo: development | staging | production | test
NODE_ENV=development
# Puerto HTTP de la API
PORT=3000

# ──────────────────────────── MariaDB ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=queueforge
# Log de SQL (solo desarrollo)
DB_LOGGING=false
# Sincroniza el esquema automáticamente. SOLO para tests/e2e. Nunca en producción.
DB_SYNCHRONIZE=false

# ───────────────────────────── Redis ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────── Cola / Worker ────────────────────────
# Jobs procesados en paralelo por instancia
QUEUE_CONCURRENCY=5
# Reintentos máximos por job
QUEUE_MAX_ATTEMPTS=3
# Backoff base (ms) entre reintentos
QUEUE_BACKOFF_MS=1000
# Cron del despachador que reencola los jobs pendientes (formato de 6 campos con segundos)
QUEUE_DISPATCH_CRON=*/10 * * * * *

# ─────────────────────────── Rate limit ───────────────────────────
# Ventana de tiempo (ms)
RATE_LIMIT_TTL=60000
# Máximo de peticiones por ventana y por cliente
RATE_LIMIT_LIMIT=100
